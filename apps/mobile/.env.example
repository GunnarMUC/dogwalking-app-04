# ==========================================
# DogWalking Mobile App - Environment Variables
# ==========================================
#
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control
#

# ==========================================
# REQUIRED VARIABLES
# ==========================================

# API Base URL
# Point to your backend API server
# Development: http://localhost:5173 or your local IP (e.g., http://192.168.1.100:5173)
# Production: https://your-api-domain.com
EXPO_PUBLIC_API_URL=http://localhost:5173

# Alternative API URL variable (legacy support)
API_BASE_URL=http://localhost:5173

# ==========================================
# OPTIONAL VARIABLES
# ==========================================

# Expo Project Configuration
# EXPO_PROJECT_ID=your-expo-project-id

# ==========================================
# DEVELOPMENT TIPS
# ==========================================
#
# For Testing on Physical Devices:
# - Replace localhost with your computer's local IP address
# - Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:5173
#   (Find your IP: Mac: System Preferences > Network, Windows: ipconfig)
#
# For iOS Simulator:
# - Use http://localhost:5173
#
# For Android Emulator:
# - Use http://10.0.2.2:5173 (Android emulator's special alias for localhost)
#   OR use your computer's local IP
#
# ==========================================
# PRODUCTION CHECKLIST
# ==========================================
#
# Before deploying to production:
# ✅ EXPO_PUBLIC_API_URL points to production API
# ✅ API uses HTTPS (not HTTP)
# ✅ Configure app.json with correct bundle identifiers
# ✅ Update Expo project settings
# ✅ Test on both iOS and Android
#
